{
  "openapi": "3.0.3",
  "info": {
    "title": "Truss API",
    "description": "HTTP operations exposed by the public @truss-security/truss-sdk \n\nAll routes require an API key (x-api-key)",
    "version": "0.5.1",
    "contact": {
      "name": "Truss Security",
      "url": "https://www.truss-security.com"
    }
  },
  "servers": [
    {
      "url": "https://api.truss-security.com",
      "description": "Truss API"
    }
  ],
  "security": [{ "ApiKeyAuth": [] }],
  "paths": {
    "/product/search": {
      "post": {
        "summary": "Search products",
        "operationId": "searchProducts",
        "requestBody": {
          "required": false,
          "content": {
            "application/json": {
              "schema": { "$ref": "#/components/schemas/SearchProductsRequest" },
              "examples": {
                "filterOnly": {
                  "summary": "FilterQL only",
                  "value": {
                    "filterExpression": "category = 'Malware'",
                    "limit": 10,
                    "page": 1
                  }
                },
                "withDates": {
                  "summary": "With date window",
                  "value": {
                    "filterExpression": "category = 'Malware'",
                    "startDate": "2026-01-01",
                    "endDate": "2026-01-31",
                    "limit": 10,
                    "page": 1
                  }
                },
                "withSorting": {
                  "summary": "With sorting",
                  "value": {
                    "filterExpression": "category = 'Malware'",
                    "order_by": "pub_date",
                    "order_direction": "desc",
                    "limit": 10,
                    "page": 1
                  }
                }
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "Paginated product hits",
            "content": {
              "application/json": {
                "schema": { "$ref": "#/components/schemas/SearchProductsResponse" }
              }
            }
          },
          "400": {
            "description": "Invalid body or parameters",
            "content": {
              "application/json": {
                "schema": { "$ref": "#/components/schemas/ErrorMessage" }
              }
            }
          },
          "401": { "description": "Missing or invalid API key" },
          "500": {
            "description": "Server error",
            "content": {
              "application/json": {
                "schema": { "$ref": "#/components/schemas/ErrorMessage" }
              }
            }
          }
        }
      }
    },
    "/product/search/stix": {
      "post": {
        "summary": "Search products STIX",
        "operationId": "searchProductsStix",
        "requestBody": {
          "required": false,
          "content": {
            "application/json": {
              "schema": { "$ref": "#/components/schemas/SearchProductsStixRequest" },
              "examples": {
                "filterOnly": {
                  "summary": "FilterQL + small page",
                  "description": "Return a STIX bundle for the first page of Malware products.",
                  "value": {
                    "filterExpression": "category = 'Malware'",
                    "limit": 10,
                    "page": 1
                  }
                },
                "withDateWindow": {
                  "summary": "FilterQL with timestamp range",
                  "description": "Same date rules as JSON search; `endDate` requires `startDate` or `days`.",
                  "value": {
                    "filterExpression": "source != 'Test'",
                    "startDate": "2026-01-01",
                    "endDate": "2026-01-31",
                    "limit": 10,
                    "page": 1
                  }
                },
                "recentDays": {
                  "summary": "Last N days",
                  "value": {
                    "filterExpression": "source = 'OpenPhish'",
                    "days": 30,
                    "limit": 10,
                    "page": 1
                  }
                },
                "withSorting": {
                  "summary": "Explicit sort",
                  "description": "`order_by` / `order_direction` match `POST /product/search` (max `limit` 300 on this route).",
                  "value": {
                    "filterExpression": "category = 'Malware'",
                    "order_by": "timestamp",
                    "order_direction": "desc",
                    "limit": 10,
                    "page": 1
                  }
                }
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "STIX bundle for the current page. Pagination is duplicated in headers for clients that do not parse the bundle.",
            "headers": {
              "X-Total-Count": {
                "description": "Total matching products (all pages).",
                "schema": { "type": "integer" }
              },
              "X-Page": {
                "description": "Current page (1-based).",
                "schema": { "type": "integer" }
              },
              "X-Total-Pages": {
                "description": "Total pages for this `limit`.",
                "schema": { "type": "integer" }
              },
              "Link": {
                "description": "Optional RFC 5988 `Link` header for pagination.",
                "schema": { "type": "string" }
              }
            },
            "content": {
              "application/stix+json": {
                "schema": { "$ref": "#/components/schemas/StixBundle" }
              }
            }
          },
          "400": {
            "description": "Invalid body, unknown keys, or `limit` > 300",
            "content": {
              "application/json": {
                "schema": { "$ref": "#/components/schemas/ErrorMessage" }
              }
            }
          },
          "401": { "description": "Missing or invalid API key" },
          "500": {
            "description": "Server error",
            "content": {
              "application/json": {
                "schema": { "$ref": "#/components/schemas/ErrorMessage" }
              }
            }
          }
        }
      }
    },
    "/product/{id}": {
      "get": {
        "summary": "Get product (JSON)",
        "operationId": "getProduct",
        "parameters": [
          {
            "name": "id",
            "in": "path",
            "required": true,
            "description": "Numeric primary key or `truss_prod_id` (ULID string).",
            "schema": {
              "oneOf": [{ "type": "integer" }, { "type": "string" }]
            }
          }
        ],
        "responses": {
          "200": {
            "description": "Product record",
            "content": {
              "application/json": {
                "schema": { "$ref": "#/components/schemas/GetProductResponse" }
              }
            }
          },
          "400": {
            "description": "Missing id",
            "content": {
              "application/json": {
                "schema": { "$ref": "#/components/schemas/ErrorMessage" }
              }
            }
          },
          "404": {
            "description": "Product not found",
            "content": {
              "application/json": {
                "schema": { "$ref": "#/components/schemas/ErrorMessage" }
              }
            }
          },
          "401": { "description": "Missing or invalid API key" },
          "500": {
            "description": "Server error",
            "content": {
              "application/json": {
                "schema": { "$ref": "#/components/schemas/ErrorMessage" }
              }
            }
          }
        }
      }
    },
    "/product/{id}/stix": {
      "get": {
        "summary": "Get product STIX",
        "operationId": "getProductStix",
        "parameters": [
          {
            "name": "id",
            "in": "path",
            "required": true,
            "description": "Truss product ID (ULID).",
            "schema": { "type": "string" }
          }
        ],
        "responses": {
          "200": {
            "description": "STIX bundle for the product",
            "content": {
              "application/stix+json": {
                "schema": { "$ref": "#/components/schemas/StixBundle" }
              }
            }
          },
          "400": {
            "description": "Missing id",
            "content": {
              "application/json": {
                "schema": { "$ref": "#/components/schemas/ErrorMessage" }
              }
            }
          },
          "404": {
            "description": "Product not found",
            "content": {
              "application/json": {
                "schema": { "$ref": "#/components/schemas/ErrorMessage" }
              }
            }
          },
          "401": { "description": "Missing or invalid API key" },
          "500": {
            "description": "Server error",
            "content": {
              "application/json": {
                "schema": { "$ref": "#/components/schemas/ErrorMessage" }
              }
            }
          }
        }
      }
    }
  },
  "components": {
    "securitySchemes": {
      "ApiKeyAuth": {
        "type": "apiKey",
        "in": "header",
        "name": "x-api-key",
        "description": "API key issued for your Truss account (access type must allow these routes)."
      }
    },
    "schemas": {
      "SearchProductsRequest": {
        "type": "object",
        "additionalProperties": false,
        "description": "Body keys allowed by `POST /product/search` (`searchProducts` handler). Matches `@truss-security/truss-sdk` `SearchProductsRequest` except the SDK-only `filter` field, which must not be sent to the API.",
        "properties": {
          "filterExpression": {
            "type": "string",
            "description": "FilterQL expression, e.g. `category = 'Malware' AND source != 'Test'`. Omit or use an empty string for no attribute filter (still subject to date filters if provided)."
          },
          "startDate": {
            "description": "Restrict to products with `timestamp` on or after this instant. String (ISO or human-readable) or Unix epoch **milliseconds** number.",
            "oneOf": [{ "type": "string" }, { "type": "number" }]
          },
          "endDate": {
            "description": "Restrict to products with `timestamp` on or before this instant. **Requires** `startDate` or `days` (API validation).",
            "oneOf": [{ "type": "string" }, { "type": "number" }]
          },
          "days": {
            "type": "integer",
            "minimum": 0,
            "description": "When **> 0**, sets the window start to “now minus N days” on `timestamp` (same semantics as SDK). `0` is accepted by the API but does not apply a days-based window."
          },
          "page": {
            "type": "integer",
            "minimum": 1,
            "default": 1,
            "description": "1-based page index."
          },
          "limit": {
            "type": "integer",
            "minimum": 1,
            "description": "Requested page size (any integer ≥ 1 is accepted by the handler). `searchProducts` in `truss-api` uses `effectiveLimit = min(limit, 250)` (`PRODUCT_SEARCH_MAX_LIMIT_WITH_FILTER`) for every query; the JSON response echoes the **applied** page size in `limit`, not necessarily the number you sent."
          },
          "order_by": {
            "type": "string",
            "enum": ["pub_date", "downloads", "rating", "timestamp"],
            "description": "Prisma sort field. **Supported.** If omitted, the API uses `timestamp`."
          },
          "order_direction": {
            "type": "string",
            "enum": ["asc", "desc"],
            "description": "Sort direction. **Supported.** If omitted, the API uses `desc`."
          }
        }
      },
      "SearchProductsStixRequest": {
        "type": "object",
        "additionalProperties": false,
        "description": "Same allowed keys as `POST /product/search` (`SearchProductsStixRequest` in the SDK). STIX search additionally rejects `limit` **> 300**.",
        "properties": {
          "filterExpression": { "type": "string" },
          "startDate": { "oneOf": [{ "type": "string" }, { "type": "number" }] },
          "endDate": { "oneOf": [{ "type": "string" }, { "type": "number" }] },
          "days": { "type": "integer", "minimum": 0 },
          "page": { "type": "integer", "minimum": 1, "default": 1 },
          "limit": { "type": "integer", "minimum": 1, "maximum": 300 },
          "order_by": {
            "type": "string",
            "enum": ["pub_date", "downloads", "rating", "timestamp"],
            "description": "Same as product search; optional, defaults to `timestamp`."
          },
          "order_direction": {
            "type": "string",
            "enum": ["asc", "desc"],
            "description": "Same as product search; optional, defaults to `desc`."
          }
        }
      },
      "SearchProductResponse": {
        "type": "object",
        "description": "Single product in `products[]`; matches `SearchProductResponse` / `Product` from `@truss-security/truss-sdk`. Shaped like `transformProduct` in `truss-api` (relation arrays default to `[]`). **Embeddings** (`title_embedding`, `content_embedding`) are not returned on this route.",
        "properties": {
          "id": { "type": "integer", "format": "int64" },
          "truss_prod_id": { "type": "string", "nullable": true },
          "timestamp": { "type": "string", "format": "date-time" },
          "version": { "type": "integer", "nullable": true },
          "latest_version": { "type": "integer", "nullable": true },
          "title": { "type": "string", "nullable": true },
          "type": { "type": "string" },
          "category": { "type": "string" },
          "source": { "type": "string" },
          "pub_date": { "type": "string", "format": "date-time", "nullable": true },
          "indicators_hash": { "type": "string", "nullable": true },
          "downloads": { "type": "integer", "nullable": true },
          "rating": { "type": "number", "nullable": true },
          "author": { "type": "array", "items": { "type": "string" } },
          "industry": { "type": "array", "items": { "type": "string" } },
          "region": { "type": "array", "items": { "type": "string" } },
          "tags": { "type": "array", "items": { "type": "string" } },
          "validators": { "type": "array", "items": { "type": "string" } },
          "reference": { "type": "array", "items": { "type": "string" } },
          "indicators": {
            "type": "object",
            "additionalProperties": {
              "type": "array",
              "items": { "type": "string" }
            }
          },
          "similarity_score": {
            "type": "number",
            "minimum": 0,
            "maximum": 1,
            "description": "Defined on `SearchProductResponse` in the SDK for vector-style results; **not** set on standard `POST /product/search` rows from Prisma `transformProduct`."
          },
          "description": {
            "type": "string",
            "description": "Optional SDK field; not populated by the current FilterQL search path unless added later."
          }
        },
        "required": ["type", "category", "source"]
      },
      "GetProductResponse": {
        "type": "object",
        "required": ["product"],
        "description": "Body returned by `GET /product/{id}` (`getProduct` handler). Matches `GetProductResponse` in `@truss-security/truss-sdk`.",
        "properties": {
          "product": { "$ref": "#/components/schemas/SearchProductResponse" }
        }
      },
      "SearchProductsResponse": {
        "type": "object",
        "required": ["products", "total", "page", "limit", "hasMore"],
        "properties": {
          "products": {
            "type": "array",
            "items": { "$ref": "#/components/schemas/SearchProductResponse" }
          },
          "total": { "type": "integer", "minimum": 0 },
          "page": { "type": "integer", "minimum": 1 },
          "limit": { "type": "integer", "minimum": 1 },
          "hasMore": { "type": "boolean" },
          "debug": {
            "type": "object",
            "description": "Included on successful `POST /product/search` responses from the current Lambda handler (echo of request + counts). Mirrors `SearchProductsResponse['debug']` in the SDK.",
            "properties": {
              "searchParams": { "type": "object", "additionalProperties": true },
              "resultCount": { "type": "integer" },
              "hasStartDate": { "type": "boolean" },
              "hasEndDate": { "type": "boolean" },
              "hasDays": { "type": "boolean" },
              "startDateValue": {},
              "endDateValue": {},
              "daysValue": { "type": "integer", "nullable": true }
            }
          }
        }
      },
      "StixBundle": {
        "type": "object",
        "required": ["type", "id", "spec_version", "objects"],
        "description": "STIX 2.1 bundle (`ProductStixResponse` in the SDK).",
        "properties": {
          "type": { "type": "string", "enum": ["bundle"] },
          "id": { "type": "string" },
          "spec_version": { "type": "string", "enum": ["2.1"] },
          "objects": {
            "type": "array",
            "items": { "$ref": "#/components/schemas/StixObject" }
          }
        }
      },
      "StixObject": {
        "description": "Subset of STIX object types returned for products (identity, report, indicator).",
        "oneOf": [
          { "$ref": "#/components/schemas/StixIdentity" },
          { "$ref": "#/components/schemas/StixReport" },
          { "$ref": "#/components/schemas/StixIndicator" }
        ]
      },
      "StixIdentity": {
        "type": "object",
        "required": ["type", "id", "identity_class", "name"],
        "properties": {
          "type": { "type": "string", "enum": ["identity"] },
          "id": { "type": "string" },
          "spec_version": { "type": "string" },
          "created": { "type": "string", "format": "date-time" },
          "modified": { "type": "string", "format": "date-time" },
          "identity_class": { "type": "string", "enum": ["organization"] },
          "name": { "type": "string" }
        }
      },
      "StixReport": {
        "type": "object",
        "required": ["type", "id", "name", "report_types", "published", "object_refs", "created_by_ref"],
        "properties": {
          "type": { "type": "string", "enum": ["report"] },
          "id": { "type": "string" },
          "spec_version": { "type": "string" },
          "created": { "type": "string", "format": "date-time" },
          "modified": { "type": "string", "format": "date-time" },
          "name": { "type": "string" },
          "description": { "type": "string" },
          "report_types": { "type": "array", "items": { "type": "string" } },
          "published": { "type": "string", "format": "date-time" },
          "object_refs": { "type": "array", "items": { "type": "string" } },
          "created_by_ref": { "type": "string" },
          "external_references": {
            "type": "array",
            "items": {
              "type": "object",
              "properties": {
                "source_name": { "type": "string" },
                "url": { "type": "string" },
                "description": { "type": "string" }
              }
            }
          }
        }
      },
      "StixIndicator": {
        "type": "object",
        "required": ["type", "id", "pattern", "pattern_type", "valid_from", "indicator_types", "created_by_ref"],
        "properties": {
          "type": { "type": "string", "enum": ["indicator"] },
          "id": { "type": "string" },
          "spec_version": { "type": "string" },
          "created": { "type": "string", "format": "date-time" },
          "modified": { "type": "string", "format": "date-time" },
          "name": { "type": "string" },
          "description": { "type": "string" },
          "pattern": { "type": "string" },
          "pattern_type": { "type": "string", "enum": ["stix"] },
          "valid_from": { "type": "string", "format": "date-time" },
          "indicator_types": { "type": "array", "items": { "type": "string" } },
          "created_by_ref": { "type": "string" },
          "external_references": {
            "type": "array",
            "items": {
              "type": "object",
              "properties": {
                "source_name": { "type": "string" },
                "url": { "type": "string" },
                "description": { "type": "string" }
              }
            }
          }
        }
      },
      "ErrorMessage": {
        "type": "object",
        "properties": {
          "error": { "type": "string" },
          "message": { "type": "string" }
        },
        "additionalProperties": true
      }
    }
  }
}
